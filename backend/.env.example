# Django Secret Key - MUST be unique and random in production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here

# JWT Secret Key for token signing (REQUIRED in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your-jwt-secret-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated for production)
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,0.0.0.0

# SQLite database path (optional override for Windows/OneDrive setups)
# SQLITE_DB_PATH=C:/Users/YourUser/AppData/Local/factly-db.sqlite3
STRICT_SQLITE_PATH=False
ALLOW_MEMORY_DB=True

# CORS origins (comma-separated) - default allows localhost:3000 for development
ALLOWED_CORS=http://localhost:3000

# Email Configuration (for password reset functionality)
# Option 1: Resend API (RECOMMENDED - free tier: 100 emails/day)
# Sign up at https://resend.com to get your API key
EMAIL_BACKEND=verification.resend_email_backend.EmailBackend
# RESEND_API_KEY=re_xxxx

# Option 2: File fallback (used when SMTP fails)
EMAIL_FILE_PATH=tmp/emails

DEFAULT_FROM_EMAIL=noreply@factly.com

# Password Reset Configuration
PASSWORD_RESET_TIMEOUT_HOURS=24
FRONTEND_URL=http://localhost:3000

# Google Fact Check API (get key at https://developers.google.com/fact-check/tools/api)
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key

# NewsLdr API (optional) - Get key at https://newsldr.com
NEWSLDR_API_KEY=your_newsldr_api_key

# NewsAPI (optional) - Get free key at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key

# NewsData.io API (optional) - Get key at https://newsdata.io
NEWSDATA_IO_KEY=your_newsdata_io_key

# Bing News API (optional) - Get key at https://azure.microsoft.com/services/cognitive-services/bing-news-search/
BING_NEWS_API_KEY=your_bing_news_api_key

# Reddit API (optional) - Get credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Application settings
CACHE_TTL=3600
MAX_API_REQUESTS_PER_MINUTE=60

# Security settings (for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
X_FRAME_OPTIONS=DENY

# Web Push VAPID Keys (for browser push notifications)
# Generate with: python -c "from py_vapid import Vapid; vapid = Vapid(); vapid.generate_keys(); print('PUBLIC:', vapid.public_key.decode()); print('PRIVATE:', vapid.private_key.decode())"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# GitHub OAuth (for GitHub Sign-In)
# Create OAuth App at: https://github.com/settings/developers
# Callback URL: http://localhost:8000/api/verification/auth/github/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Upload limits (bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
