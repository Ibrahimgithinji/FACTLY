# Django Secret Key - MUST be unique and random in production
DJANGO_SECRET_KEY=django-insecure-factly-dev-key-change-in-production

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated for production)
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,0.0.0.0

# CORS origins (comma-separated) - default allows localhost:3000 for development
ALLOWED_CORS=http://localhost:3000

# Email Configuration (for password reset functionality)
# Using FallbackEmailBackend - tries SMTP first, falls back to file if it fails
# ----------------------------- IMPORTANT -----------------------------
# For Gmail: Generate App Password at https://myaccount.google.com/apppasswords
# For Mailtrap: Sign up at https://mailtrap.io for free credentials
# --------------------------------------------------------------------

EMAIL_BACKEND=verification.email_backend.FallbackEmailBackend

# Gmail SMTP configuration (update with your App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=ibrahgatchu@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# File fallback (used when SMTP fails)
EMAIL_FILE_PATH=tmp/emails

DEFAULT_FROM_EMAIL=noreply@factly.com

# Password Reset Configuration
PASSWORD_RESET_TIMEOUT_HOURS=24
FRONTEND_URL=http://localhost:3000

# Google Fact Check API
GOOGLE_FACT_CHECK_API_KEY=your_google_api_key_here

# NewsLdr API (optional)
NEWSLDR_API_KEY=your_newsldr_api_key_here

# NewsAPI (optional) - Get free key at https://newsapi.org
NEWSAPI_KEY=

# Application settings
CACHE_TTL=3600
MAX_API_REQUESTS_PER_MINUTE=60

# Security settings (for production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
X_FRAME_OPTIONS=DENY

# Upload limits (bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
