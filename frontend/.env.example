# Frontend Environment Variables
# =============================================================================
# IMPORTANT: This file documents the environment variables used by the frontend.
#
# SECURITY WARNING: Never put secrets (API keys, passwords, tokens) in frontend env files!
# Frontend env variables are bundled into the public JavaScript build and can be
# accessed by anyone who views your website's source code.
#
# For authentication tokens, cookies, or other secrets, use the Django backend
# API endpoints and session/cookie-based authentication instead.
# =============================================================================

# API Base URL (no trailing slash)
# This is the URL of the Django backend API
REACT_APP_API_URL=http://localhost:8000

# Optional: Development mode flag (set automatically by Create React App)
# NODE_ENV=development

# Optional: Analytics or public-facing service URLs
# REACT_APP_ANALYTICS_URL=https://analytics.example.com